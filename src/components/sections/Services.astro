---
import Container from "../ui/Container.astro";

const services = [
  {
    id: "mantenimiento",
    title: "Mantenimiento Preventivo",
    badge: "Más solicitado",
    badgeColor: "text-brand-secondary bg-brand-secondary/10",
    description:
      "Planes por kilometraje y horas de operación que alargan la vida útil de cada unidad y eliminan las paradas imprevistas.",
    includes: [
      "Cambio de aceite de motor y caja de cambios",
      "Filtros de aire, combustible y aceite",
      "Revisión de frenos, suspensión y dirección",
      "Inspección de sistema eléctrico y baterías",
    ],
    iconPath: `<path d="M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z"/>`,
  },
  {
    id: "diagnostico",
    title: "Diagnóstico Computarizado",
    badge: "Tecnología OEM",
    badgeColor: "text-brand-primary bg-brand-primary/10",
    description:
      "Escaneo con herramientas certificadas por fabricante. Identificamos la falla antes de que deje su camión varado en ruta.",
    includes: [
      "Cummins, CAT, Detroit Diesel, HOWO, Foton y Shacman",
      "Análisis de presiones, temperaturas y parámetros críticos",
      "Reporte técnico por escrito con fotografías de evidencia",
      "Seguimiento post-diagnóstico sin costo adicional",
    ],
    iconPath: `<path d="M21 3H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h7v2H8v2h8v-2h-2v-2h7c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 14H3V5h18v12zM8 13h2.5l1.5-2 1.5 3.5 1.5-7 1.5 5.5H19v-2h-1.5l-1-3.5-1.5 7-1.5-3.5L12 15H8v-2z"/>`,
  },
  {
    id: "reparacion",
    title: "Reparación Mayor",
    badge: "Garantía por escrito",
    badgeColor: "text-success bg-success/10",
    description:
      "Intervenciones de fondo en motor, transmisión y sistema hidráulico con repuestos originales y mano de obra certificada.",
    includes: [
      "Reconstrucción de motor y culata (Cummins, Detroit, CAT, HOWO)",
      "Transmisión manual y automática Allison",
      "Sistema hidráulico, diferencial y dirección asistida",
      "Garantía de trabajo entregada por escrito",
    ],
    iconPath: `<path d="M12 15.5A3.5 3.5 0 0 1 8.5 12 3.5 3.5 0 0 1 12 8.5a3.5 3.5 0 0 1 3.5 3.5 3.5 3.5 0 0 1-3.5 3.5m7.43-2.92c.04-.3.07-.62.07-.93s-.03-.64-.07-1l2.17-1.63c.2-.15.25-.42.12-.64l-2.06-3.57c-.12-.22-.39-.3-.61-.22l-2.57 1.03c-.52-.4-1.08-.73-1.69-.98l-.38-2.65C14.46 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.49.42l-.38 2.65c-.61.25-1.17.59-1.69.98L4.86 5.02c-.22-.08-.49 0-.61.22L2.19 8.81c-.13.22-.07.49.12.64L4.48 11.08c-.04.36-.07.67-.07 1s.03.64.07 1L2.31 14.71c-.2.15-.25.42-.12.64l2.06 3.57c.12.22.39.3.61.22l2.57-1.03c.52.4 1.08.73 1.69.98l.38 2.65c.03.24.24.42.49.42h4c.25 0 .46-.18.49-.42l.38-2.65c.61-.25 1.17-.58 1.69-.98l2.57 1.03c.22.08.49 0 .61-.22l2.06-3.57c.13-.22.07-.49-.12-.64l-2.17-1.63z"/>`,
  },
];
---

<section
  id="servicios"
  data-testid="services-section"
  aria-labelledby="services-heading"
  class="bg-surface-muted py-section-y-sm md:py-section-y"
>
  <Container>
    <div class="flex flex-col gap-12">

      <!-- Section header -->
      <div class="text-center max-w-2xl mx-auto">
        <h2
          id="services-heading"
          class="font-display font-bold text-ink leading-tight"
          style={`font-size: var(--text-section-title)`}
        >
          Nuestros Servicios
        </h2>
        <p class="mt-4 text-ink-muted leading-body">
          Cobertura completa del ciclo de vida de su flota: desde el mantenimiento rutinario hasta la intervención de emergencia.
        </p>
      </div>

      <!-- Service cards -->
      <div class="grid md:grid-cols-3 gap-8">
        {services.map((s) => (
          <article
            data-testid={`service-card-${s.id}`}
            class="flex flex-col gap-6 bg-surface rounded-card p-8 shadow-card border border-border relative overflow-hidden"
          >
            <!-- Top accent line -->
            <div class="absolute top-0 left-0 right-0 h-1 bg-brand-primary rounded-t-card opacity-80" aria-hidden="true"/>

            <!-- Icon + badge row -->
            <div class="flex items-start justify-between gap-3 pt-1">
              <div class="w-12 h-12 rounded-xl bg-brand-primary/10 flex items-center justify-center text-brand-primary flex-shrink-0">
                <svg aria-hidden="true" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <Fragment set:html={s.iconPath} />
                </svg>
              </div>
              <span class={`text-xs font-semibold px-2.5 py-1 rounded-pill whitespace-nowrap ${s.badgeColor}`}>
                {s.badge}
              </span>
            </div>

            <!-- Title + description -->
            <div class="flex flex-col gap-2">
              <h3 class="font-display font-bold text-ink text-xl leading-tight">
                {s.title}
              </h3>
              <p class="text-ink-muted leading-body text-sm">{s.description}</p>
            </div>

            <!-- Includes checklist -->
            <ul class="flex flex-col gap-2.5 mt-auto" role="list">
              {s.includes.map((item) => (
                <li class="flex items-start gap-2.5 text-sm text-ink-muted">
                  <svg aria-hidden="true" width="16" height="16" viewBox="0 0 16 16" fill="none" class="flex-shrink-0 mt-0.5 text-success" stroke="currentColor" stroke-width="2">
                    <path d="M3 8l3.5 3.5L13 4.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>

    </div>
  </Container>
</section>
