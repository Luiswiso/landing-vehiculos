---
import { getLandingStats } from "../../lib/cms/landing-stats";
import PartnersSkeleton from "./PartnersSkeleton.astro";

let partners: Array<{
  id: string;
  name: string;
  logoUrl: string;
  altText: string;
}> = [];
let errorMessage: string | undefined;

try {
  const stats = await getLandingStats();
  partners = stats.partners;
} catch {
  errorMessage =
    "Los partners no están disponibles en este momento.";
}

// Logo dimensions resolved from CSS custom properties at build time.
// Using numeric pixel values that match the @theme tokens:
// --logo-width: 140px, --logo-height: 60px
const LOGO_WIDTH = 140;
const LOGO_HEIGHT = 60;
---

{
  errorMessage ? (
    <section
      data-testid="partners-section"
      aria-labelledby="partners-heading"
      class="bg-surface-muted py-section-y-sm"
    >
      <div class="max-w-screen-xl mx-auto px-4 text-center">
        <h2 id="partners-heading" class="text-section-title font-display font-bold text-ink mb-8">
          Nuestros Partners
        </h2>
        <p aria-live="polite" role="status" class="text-ink-muted">
          {errorMessage}
        </p>
      </div>
    </section>
  ) : partners.length === 0 ? null : (
    <section
      data-testid="partners-section"
      aria-labelledby="partners-heading"
      class="bg-surface-muted py-section-y-sm"
    >
      <div class="max-w-screen-xl mx-auto px-4">
        <h2
          id="partners-heading"
          class="text-section-title font-display font-bold text-ink text-center mb-8"
        >
          Nuestros Partners
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 items-center">
          {partners.map((partner) => (
            <div class="flex items-center justify-center p-4">
              <img
                src={partner.logoUrl}
                alt={partner.altText}
                width={LOGO_WIDTH}
                height={LOGO_HEIGHT}
                loading="lazy"
                decoding="async"
                class="object-contain"
                style="width: var(--logo-width); height: var(--logo-height);"
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<Fragment slot="fallback">
  <PartnersSkeleton />
</Fragment>
