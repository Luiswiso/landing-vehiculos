---
// StatsStripSkeleton — fallback slot for StatsStrip server:defer island.
// Height must match the resolved StatsStrip height (--spacing-stats-strip token)
// to achieve CLS = 0.
interface Props {
  errorMessage?: string;
}
const { errorMessage } = Astro.props;
---

<div
  data-testid="stats-strip-skeleton"
  class="bg-brand-primary min-h-stats-strip flex items-center justify-center w-full"
  aria-hidden={errorMessage ? undefined : "true"}
>
  {
    errorMessage ? (
      <p
        aria-live="polite"
        role="status"
        class="text-danger text-sm text-center px-4"
      >
        {errorMessage}
      </p>
    ) : (
      <div class="flex gap-8 items-center justify-center w-full px-8 flex-wrap">
        {Array.from({ length: 5 }).map(() => (
          <div class="flex flex-col items-center gap-2 animate-pulse">
            <div class="h-10 w-24 rounded-card" style="background:rgba(255,255,255,0.12)" />
            <div class="h-4 w-20 rounded-pill" style="background:rgba(255,255,255,0.08)" />
          </div>
        ))}
      </div>
    )
  }
</div>
