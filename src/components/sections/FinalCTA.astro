---
import Container from "../ui/Container.astro";
import { CtaConfigSchema } from "../../lib/schemas/cta";

const ctaConfig = CtaConfigSchema.parse({
  href: "mailto:contacto@flotapesada.com",
  label: "Solicitar diagnóstico gratuito",
  description:
    "Un técnico certificado evalúa su flota, identifica riesgos y le entrega un plan de mantenimiento sin costo ni compromiso.",
});

const trustSignals = [
  { icon: `<path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`, label: "Sin contrato permanente" },
  { icon: `<path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`, label: "Respuesta en menos de 24 h" },
  { icon: `<path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>`, label: "Diagnóstico sin costo" },
];
---

<section
  id="contacto"
  aria-labelledby="cta-heading"
  class="relative bg-brand-primary py-section-y overflow-hidden"
>
  <!-- Decorative background circles -->
  <svg
    aria-hidden="true"
    class="absolute inset-0 w-full h-full pointer-events-none"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid slice"
  >
    <circle cx="10%" cy="50%" r="280" fill="none" stroke="white" stroke-width="1" opacity="0.05"/>
    <circle cx="10%" cy="50%" r="180" fill="none" stroke="white" stroke-width="1" opacity="0.05"/>
    <circle cx="90%" cy="50%" r="320" fill="none" stroke="white" stroke-width="1" opacity="0.04"/>
    <circle cx="90%" cy="50%" r="200" fill="none" stroke="white" stroke-width="1" opacity="0.04"/>
    <circle cx="50%" cy="50%" r="500" fill="none" stroke="white" stroke-width="1" opacity="0.03"/>
  </svg>

  <Container>
    <div class="relative flex flex-col items-center gap-10 text-center max-w-3xl mx-auto">

      <!-- Trust signals -->
      <div class="flex flex-wrap justify-center gap-3">
        {trustSignals.map((t) => (
          <div class="flex items-center gap-2 px-4 py-2 rounded-pill border border-white/20 bg-white/10 backdrop-blur-sm">
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0">
              <Fragment set:html={t.icon} />
            </svg>
            <span class="text-sm font-medium text-white/90">{t.label}</span>
          </div>
        ))}
      </div>

      <!-- Headline -->
      <div class="flex flex-col gap-4">
        <h2
          id="cta-heading"
          class="font-display font-bold text-surface leading-tight"
          style={`font-size: var(--text-section-title)`}
        >
          Proteja su Flota.<br/>
          Elimine las Paradas Imprevistas.
        </h2>
        <p class="text-surface/80 leading-body text-lg max-w-xl mx-auto">
          {ctaConfig.description}
        </p>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 items-center w-full sm:w-auto">
        <a
          data-testid="cta-final"
          href={ctaConfig.href}
          class="inline-flex items-center justify-center gap-3 w-full sm:w-auto px-10 py-5 bg-brand-secondary text-ink font-bold text-lg rounded-pill hover:brightness-110 transition-all shadow-card"
        >
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
          {ctaConfig.label}
        </a>

        <a
          href="tel:+582125550100"
          class="inline-flex items-center justify-center gap-3 w-full sm:w-auto px-8 py-5 rounded-pill border-2 border-white/40 text-white font-semibold text-lg hover:bg-white/10 transition-colors"
        >
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          +58 212 555-0100
        </a>
      </div>

      <!-- Social proof footer -->
      <p class="text-white/50 text-sm">
        Más de <strong class="text-white/75">50 empresas y operadores</strong> con flota activa en toda la región ya confían en nosotros.
      </p>

    </div>
  </Container>
</section>
